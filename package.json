{
  "name": "quicksave-monorepo",
  "version": "0.8.8",
  "private": true,
  "description": "Remote git control PWA with E2E encryption",
  "scripts": {
    "dev": "pnpm dev:pwa",
    "dev:pwa": "pnpm --filter quicksave-pwa dev",
    "dev:agent": "pnpm --filter @sumicom/quicksave dev",
    "dev:relay": "pnpm --filter quicksave-relay dev",
    "build": "pnpm -r build",
    "build:pwa": "pnpm --filter quicksave-pwa build",
    "build:agent": "pnpm --filter @sumicom/quicksave build",
    "build:relay": "pnpm --filter quicksave-relay build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepare": "git config core.hooksPath scripts"
  },
  "keywords": [
    "git",
    "pwa",
    "webrtc",
    "e2e-encryption",
    "remote-control"
  ],
  "author": "King Young Technology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingYoung-Sumicom/quicksave.git"
  },
  "homepage": "https://github.com/KingYoung-Sumicom/quicksave#readme",
  "bugs": {
    "url": "https://github.com/KingYoung-Sumicom/quicksave/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "vitest": "^1.2.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
