{
  "name": "quicksave-pwa",
  "version": "0.8.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tunnel": "vite & sleep 2 && npx ngrok http 5173 --log stdout",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@sumicom/quicksave-message-bus": "workspace:*",
    "@sumicom/quicksave-shared": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.0",
    "highlight.js": "^11.11.1",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intl": "^6.8.9",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
