QUICKSAVE_SIGNALING_URL=ws://localhost:8080

# Public VAPID key exposed to the service worker for push subscription.
# Must match VAPID_PUBLIC_KEY in apps/relay/.env.
#
# CI note: Vite inlines this at build time, so `.env` is not enough for
# deployed builds. The GitHub Actions workflow reads it from the `staging`
# / `production` environment variable `VAPID_PUBLIC_KEY` (see
# .github/workflows/deploy.yml). If this is empty in a deployed bundle, the
# settings page will show "push isn't configured for this deployment".
VITE_VAPID_PUBLIC_KEY=
