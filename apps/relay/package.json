{
  "name": "quicksave-relay",
  "version": "0.8.7",
  "description": "Quicksave relay server for WebSocket connection brokering",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/bundle.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sumicom/quicksave-shared": "workspace:*",
    "@sumicom/ws-relay": "^0.1.1",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
