{
  "name": "@sumicom/quicksave",
  "version": "0.8.8",
  "description": "Quicksave agent - remote git control CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingYoung-Sumicom/quicksave.git",
    "directory": "apps/agent"
  },
  "homepage": "https://github.com/KingYoung-Sumicom/quicksave#readme",
  "bugs": {
    "url": "https://github.com/KingYoung-Sumicom/quicksave/issues"
  },
  "keywords": [
    "git",
    "cli",
    "remote",
    "quicksave"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "branch": "stable"
  },
  "bin": {
    "quicksave": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/stamp-build-id.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "regen-codex-schema": "bash scripts/regen-codex-schema.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@anthropic-ai/sdk": "^0.71.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sumicom/quicksave-message-bus": "workspace:*",
    "@sumicom/quicksave-shared": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.22.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
