# Quicksave Environment Configuration
# Copy to .env and adjust for your setup.
# All values below are optional — defaults work for single-machine development.

# --- Signaling / Relay ---
# WebSocket URL of the relay server (used by both agent and PWA).
# Default: ws://localhost:8080
QUICKSAVE_SIGNALING_URL=ws://localhost:8080

# --- PWA ---
# Base URL where the PWA is served (used in pairing QR codes and manifest).
# Default: http://localhost:5173
QUICKSAVE_PWA_URL=http://localhost:5173

# --- Relay (apps/relay) ---
# VAPID keys for Web Push notifications. Generate with:
#   npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost

# --- Deployment (scripts/setup-server.sh) ---
# Domain for production/staging deployment.
# Default: localhost
DOMAIN=localhost
